{
  "info": {
    "name": "FIT4110 Lab05 Analytics",
    "_postman_id": "lab05-analytics-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      },
      "event": [{"listen": "test","script": {"exec": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Service ok', function() { var j = pm.response.json(); pm.expect(j.status).to.eql('ok'); });"
      ]}}]
    },
    {
      "name": "Get Telemetry",
      "request": {
        "method": "GET",
        "header": [{"key": "Authorization","value": "Bearer {{authToken}}"}],
        "url": "{{baseUrl}}/telemetry"
      },
      "event": [{"listen": "test","script": {"exec": [
        "pm.test('Status 200', function() { pm.response.to.have.status(200); });",
        "pm.test('Has items', function() { pm.expect(pm.response.json()).to.have.property('items'); });"
      ]}}]
    },
